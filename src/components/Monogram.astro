---
interface Props {
  /** "draw" = animated preloader mark with field-tinted nodes; "sm" = compact */
  variant?: "draw" | "sm";
  class?: string;
}
const { variant, class: cls = "" } = Astro.props;
---

{
  variant === "draw" ? (
    <svg class={`monogram monogram--draw ${cls}`} viewBox="0 0 120 120" aria-hidden="true">
      <circle class="mg-ring" cx="60" cy="60" r="54" pathLength="1" />
      <path class="mg-a" d="M38 88 L60 32 L82 88" pathLength="1" />
      <path class="mg-bar" d="M47 70 L73 70" pathLength="1" />
      <g class="mg-nodes">
        <circle cx="60" cy="32" r="2.8" />
        <circle cx="38" cy="88" r="2.8" />
        <circle cx="82" cy="88" r="2.8" />
      </g>
    </svg>
  ) : (
    <svg
      class={`monogram ${variant === "sm" ? "monogram--sm" : ""} ${cls}`}
      viewBox="0 0 120 120"
      aria-hidden="true"
    >
      <circle cx="60" cy="60" r="54" />
      <path d="M38 88 L60 32 L82 88" />
      <path d="M47 70 L73 70" />
    </svg>
  )
}
